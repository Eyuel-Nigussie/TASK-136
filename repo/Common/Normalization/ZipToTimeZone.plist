    <key>980</key><string>America/Los_Angeles</string>
    <key>970</key><string>America/Los_Angeles</string>

    <!-- Alaska / Hawaii -->
    <key>995</key><string>America/Anchorage</string>
    <key>996</key><string>America/Anchorage</string>
    <key>967</key><string>Pacific/Honolulu</string>
    <key>968</key><string>Pacific/Honolulu</string>
</dict>
</plist>
