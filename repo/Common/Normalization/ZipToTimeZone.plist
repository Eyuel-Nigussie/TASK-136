<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
    ZIP prefix (first 3 digits) → IANA time-zone identifier. Seed dataset —
    expanded in a data refresh task. See questions.md Q15.
    Consumed by CMTimeZoneResolver; unknown prefixes fall back to the
    device's current time zone with a warning.
-->
<dict>
    <key>default</key><string>America/New_York</string>

    <!-- Eastern -->
    <key>010</key><string>America/New_York</string>
    <key>020</key><string>America/New_York</string>
    <key>100</key><string>America/New_York</string>
    <key>101</key><string>America/New_York</string>
    <key>110</key><string>America/New_York</string>
    <key>190</key><string>America/New_York</string>
    <key>200</key><string>America/New_York</string>
    <key>220</key><string>America/New_York</string>
    <key>280</key><string>America/New_York</string>
    <key>300</key><string>America/New_York</string>
    <key>331</key><string>America/New_York</string>
    <key>350</key><string>America/New_York</string>

    <!-- Central -->
    <key>440</key><string>America/Chicago</string>
    <key>600</key><string>America/Chicago</string>
    <key>630</key><string>America/Chicago</string>
    <key>660</key><string>America/Chicago</string>
    <key>700</key><string>America/Chicago</string>
    <key>750</key><string>America/Chicago</string>
    <key>770</key><string>America/Chicago</string>

